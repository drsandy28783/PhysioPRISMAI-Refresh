# ==================================
# PhysiologicPRISM - Environment Variables
# ==================================
# ⚠️ IMPORTANT: COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# ⚠️ NEVER COMMIT .env TO GIT!
#
# This file documents all environment variables needed for PhysiologicPRISM.
# Variables marked with [REQUIRED] MUST be set or the app will not start.
# Variables marked with [OPTIONAL] can be left empty or removed.
#
# For Azure deployment, see: AZURE_DEPLOYMENT_GUIDE.md
# ==================================

# ─── [REQUIRED] Flask Security ────────────────────────────────────────────────
# Flask secret key for session encryption and CSRF protection
# ⚠️ CRITICAL: Must be set to a random value in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-must-be-random-and-long

# ─── [REQUIRED] Cron Job Security ────────────────────────────────────────────
# Cron job authentication secret (for scheduled tasks like appointment reminders)
# ⚠️ CRITICAL: Required for production cron jobs to work
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=your-cron-secret-here-must-be-random-and-long

# ─── [REQUIRED] Azure Cosmos DB ──────────────────────────────────────────────
# NoSQL database (HIPAA BAA compliant)
# Get credentials from: https://portal.azure.com/ > Cosmos DB account > Keys
COSMOS_DB_ENDPOINT=https://your-cosmosdb-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-primary-key-here
COSMOS_DB_DATABASE_NAME=physiologicprism

# ─── [REQUIRED] Azure OpenAI ─────────────────────────────────────────────────
# GPT-4o for clinical decision support (HIPAA BAA compliant)
# Get credentials from: https://portal.azure.com/ > Azure OpenAI Service > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-openai-account.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL_NAME=gpt-4o

# AI Configuration
AI_TEMPERATURE=0.3  # Lower for consistent medical advice (0.0-1.0)
AI_MAX_TOKENS=2000  # Maximum tokens per response

# ─── [REQUIRED] Firebase Authentication ──────────────────────────────────────
# Firebase Auth for user authentication (mobile and web)
# Get credentials from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your-firebase-project-id

# [OPTIONAL] Service Account JSON (for local development only)
# Option 1: Explicit JSON (for local development)
# GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type": "service_account", "project_id": "...", ...}'

# Option 2: Application Default Credentials (Azure - RECOMMENDED)
# Leave empty to use managed identity - Azure will automatically authenticate
# GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── [REQUIRED] HIPAA Compliance Mode ─────────────────────────────────────────
# Set to 'true' in production - You have BAA with Microsoft Azure
HIPAA_COMPLIANT_MODE=true

# ─── [REQUIRED] Email Service (Resend) ───────────────────────────────────────
# ⚠️ CRITICAL: Required for sending registration/approval emails
# Sign up at https://resend.com/ and get your API key
# Free tier: 3,000 emails/month (100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Email Sender Configuration
FROM_EMAIL=noreply@physiologicprism.com
SUPPORT_EMAIL=support@physiologicprism.com
APP_NAME=PhysiologicPRISM

# [REQUIRED] Super Admin Configuration (receives new registration notifications)
SUPER_ADMIN_EMAIL=drsandeep@physiologicprism.com
SUPER_ADMIN_NAME=Dr Sandeep Rao

# ─── [REQUIRED] Razorpay Payment Gateway Configuration ───────────────────────
# ⚠️ CRITICAL: Required for subscription and payment processing
# Sign up at https://razorpay.com/ and get your API keys
# Test Mode Keys (for development):
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_secret_key_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Production Keys (for live deployment):
# RAZORPAY_KEY_ID=rzp_live_your_key_id_here
# RAZORPAY_KEY_SECRET=your_live_secret_key_here
# RAZORPAY_WEBHOOK_SECRET=your_live_webhook_secret_here

# Razorpay Plan IDs (create these in Razorpay dashboard with updated USD-based pricing)
# ⚠️ IMPORTANT: Create plans in Razorpay dashboard with the pricing below
# Razorpay supports both INR and USD plans - create INR plans with ₹ amounts

# Solo Plan (1 user, unlimited patients, 250 AI calls)
# Price: ₹4,200/month ($50 USD) - 250 AI calls/user baseline
RAZORPAY_PLAN_SOLO=plan_YOUR_NEW_SOLO_PLAN_ID

# Team Plans (unlimited patients, 250 AI calls per user baseline)
# Team 5: ₹19,999/month ($238 USD) - 5% volume discount ($47.50/user)
RAZORPAY_PLAN_TEAM_5=plan_YOUR_NEW_TEAM_5_PLAN_ID

# Team 10: ₹37,799/month ($450 USD) - 10% volume discount ($45/user)
RAZORPAY_PLAN_TEAM_10=plan_YOUR_NEW_TEAM_10_PLAN_ID

# Institute Plans (unlimited patients, 250 AI calls per user baseline)
# Institute 15: ₹53,599/month ($638 USD) - 15% volume discount ($42.50/user)
RAZORPAY_PLAN_INSTITUTE_15=plan_YOUR_NEW_INSTITUTE_15_PLAN_ID

# Institute 20: ₹71,399/month ($850 USD) - 15% volume discount ($42.50/user)
RAZORPAY_PLAN_INSTITUTE_20=plan_YOUR_NEW_INSTITUTE_20_PLAN_ID

# ─── [OPTIONAL] Free Trial Configuration ─────────────────────────────────────
# Control free trial availability (can leave defaults)
FREE_TRIAL_ENABLED=true
FREE_TRIAL_DAYS=14
FREE_TRIAL_PATIENTS=5
FREE_TRIAL_AI_CALLS=25

# ─── [REQUIRED] Redis Configuration (Rate Limiting) ──────────────────────────
# ⚠️ CRITICAL: Required for persistent rate limiting (security feature)
# Redis is used for persistent, distributed rate limiting
# For local development: Install Redis locally or use Docker
# For Azure production: Use Azure Cache for Redis

# Local Development (default):
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # Leave empty for local Redis without password
REDIS_DB=0

# Production (Azure Cache for Redis):
# REDIS_HOST=physiologicprism-redis.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# REDIS_SSL=true

# [OPTIONAL] Rate Limiting Configuration (can leave defaults)
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900  # 15 minutes in seconds

# ─── [OPTIONAL] Error Tracking & Monitoring (Sentry) ─────────────────────────
# Sentry provides error tracking, performance monitoring, and crash reporting
# Sign up at https://sentry.io (free tier: 5K errors/month, 10K transactions/month)
# This is optional but HIGHLY RECOMMENDED for production

# Sentry DSN (Data Source Name) - Get from Sentry project settings
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Environment name for Sentry (helps filter errors by environment)
# ENVIRONMENT=development  # or 'staging', 'production'

# App version for Sentry release tracking (optional)
# APP_VERSION=1.0.0

# ⚠️  HIPAA COMPLIANCE NOTE:
# Our Sentry integration automatically sanitizes ALL events before sending.
# PHI (Protected Health Information) is NEVER sent to Sentry.
# Sanitization includes: patient names, emails, phone numbers, medical data, tokens, passwords
# Safe to use with HIPAA_COMPLIANT_MODE=true

# ─── [OPTIONAL] Azure App Service Configuration ──────────────────────────────
# Azure App Service automatically sets this - no need to set manually
PORT=8080

# ─── [OPTIONAL] Twilio SMS & WhatsApp Configuration ──────────────────────────
# SMS and WhatsApp messaging via Twilio
# Sign up at https://www.twilio.com/ and get your credentials
# Free trial: $15 credit to test before committing

# [OPTIONAL] Enable/Disable Messaging
# Set to 'true' to enable SMS/WhatsApp features
MESSAGING_ENABLED=false

# [OPTIONAL] Mock Mode (for development without API calls/costs)
# Set to 'true' to simulate messaging without real Twilio API calls
# Set to 'false' when using real Twilio account
MESSAGING_MOCK_MODE=true

# [REQUIRED IF MESSAGING_ENABLED=true] Twilio Credentials
# Get from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here

# [REQUIRED IF MESSAGING_ENABLED=true] Twilio Phone Numbers
# SMS: Your Twilio phone number (E.164 format: +12345678900)
# TWILIO_PHONE_NUMBER=+12345678900

# WhatsApp: Your Twilio WhatsApp number (approved by Meta)
# For testing, use Twilio Sandbox: https://www.twilio.com/console/sms/whatsapp/sandbox
# TWILIO_WHATSAPP_NUMBER=+14155238886

# [OPTIONAL] App URL for Deep Links
# Used in messages to link back to your app
APP_URL=https://physiologicprism.com

# ⚠️  HIPAA COMPLIANCE NOTE FOR MESSAGING:
# 1. Sign Business Associate Agreement (BAA) with Twilio (free, requires paid account)
# 2. Enable HIPAA mode in Twilio console
# 3. NEVER send PHI in messages - use generic text with app deep links
# 4. All message templates are pre-configured to be PHI-safe
# 5. Configure webhooks in Twilio console:
#    - Incoming Messages: https://yourdomain.com/webhooks/twilio/incoming
#    - Status Callback: https://yourdomain.com/webhooks/twilio/status

# ─── [OPTIONAL] Application Settings ─────────────────────────────────────────
# Terms of Service version
TOS_VERSION=1.0

# ==================================
# Production Deployment Checklist
# ==================================
# Before deploying to production, ensure ALL [REQUIRED] variables are set:
#
# ✅ [REQUIRED] Variables:
#    - SECRET_KEY (generate random value - see above)
#    - CRON_SECRET (generate random value - see above)
#    - COSMOS_DB_ENDPOINT, COSMOS_DB_KEY, COSMOS_DB_DATABASE_NAME
#    - AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY, AZURE_OPENAI_DEPLOYMENT_NAME
#    - FIREBASE_PROJECT_ID (for authentication)
#    - RESEND_API_KEY (from https://resend.com)
#    - RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET
#    - REDIS_HOST (Azure Cache for Redis for production)
#    - FROM_EMAIL, SUPPORT_EMAIL, SUPER_ADMIN_EMAIL
#
# ✅ Security:
#    - HIPAA_COMPLIANT_MODE=true
#    - Cosmos DB security configured
#    - HTTPS enforced (handled by Azure App Service)
#    - Security headers enabled (Flask-Talisman - automatic)
#    - Input validation enabled (Marshmallow - automatic)
#
# ✅ Compliance:
#    - Signed BAA with Microsoft Azure ✅
#    - Signed BAA with Microsoft Azure OpenAI ✅
#    - All team members completed HIPAA training
#    - Privacy policy and terms updated
#
# ✅ Architecture:
#    - Authentication: Firebase Auth (Google)
#    - Database: Azure Cosmos DB (NoSQL, HIPAA BAA)
#    - AI Service: Azure OpenAI GPT-4o (HIPAA BAA)
#    - Hosting: Azure App Service
#    - Cache: Azure Cache for Redis
#    - Email: Resend
#    - Payments: Razorpay
#
# ✅ For detailed deployment instructions, see:
#    - AZURE_DEPLOYMENT_GUIDE.md
#    - PRODUCTION_READINESS_PLAN.md
